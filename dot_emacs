  (completion-styles '(orderless basic))
  (completion-category-defaults nil)
  (completion-category-overrides '((file (styles partial-completion)))))

;; consult - 検索・ナビゲーション強化
(use-package consult
  :ensure t
  :bind (("C-x b" . consult-buffer)
         ("C-x C-f" . consult-fd)  ;; fdを使用（高速）
         ("C-c f" . consult-find)
         ("C-c g" . consult-ripgrep)
         ("C-c l" . consult-line))
  :custom
  ;; プレビューの遅延を短縮
  (consult-preview-key 'any)
  :config
  ;; fdコマンドの最適化オプション
  (setq consult-fd-args '((if (executable-find "fdfind") "fdfind" "fd")
                          "--color=never"
                          "--full-path"
                          "--hidden"
                          "--exclude" ".git"
                          "--exclude" "node_modules"
                          "--exclude" ".cache"))
  ;; findコマンドのフォールバック設定
  (setq consult-find-args "find . -not ( -path */node_modules/* -prune ) -not ( -path */.git/* -prune ) -not ( -path */.cache/* -prune )"))

;; marginalia - 補完候補に追加情報を表示
(use-package marginalia
  :ensure t
  :init
  (marginalia-mode))

;; 検索履歴を保存して高速化
(use-package savehist
  :ensure nil  ;; built-in
  :init
  (savehist-mode))
